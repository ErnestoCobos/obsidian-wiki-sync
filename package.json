{
	"name": "obsidian-github-wiki-sync",
	"version": "1.0.0",
	"description": "Synchronizes your Obsidian vault with GitHub Wiki repositories",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:unit": "jest tests/plugin.test.ts tests/settings.test.ts tests/sync.test.ts",
		"test:integration": "jest tests/integration",
		"test:components": "jest tests/components",
		"test:performance": "jest tests/performance",
		"test:e2e": "jest tests/e2e",
		"test:all": "./run-tests.sh",
		"test:coverage": "jest --coverage",
		"test:coverage:ci": "CI=true jest --coverage --ci",
		"coverage:report": "jest --coverage && ./generate-coverage.sh",
		"coverage:badge": "npx make-coverage-badge --output-path ./coverage/badge.svg"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ErnestoCobos/obsidian-wiki-sync.git"
	},
	"homepage": "https://github.com/ErnestoCobos/obsidian-wiki-sync",
	"bugs": {
		"url": "https://github.com/ErnestoCobos/obsidian-wiki-sync/issues"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"github",
		"wiki",
		"sync"
	],
	"author": "Ernesto Cobos",
	"license": "MIT",
	"devDependencies": {
		"@types/jest": "^29.5.10",
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"jest": "^29.7.0",
		"jest-environment-jsdom": "^29.7.0",
		"jest-junit": "^16.0.0",
		"make-coverage-badge": "^1.2.0",
		"obsidian": "latest",
		"ts-jest": "^29.1.1",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	},
	"dependencies": {
		"@octokit/rest": "^19.0.13"
	}
}
