{
  "name": "obsidian-github-wiki-sync",
  "version": "1.0.0",
  "description": "Synchronizes your Obsidian vault with GitHub Wiki repositories",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "test": "jest tests/github-api.test.ts tests/sync.test.ts tests/settings.test.ts tests/path-conversion.test.ts",
    "test:watch": "jest --watch",
    "test:unit": "jest tests/plugin.test.ts tests/settings.test.ts tests/sync.test.ts",
    "test:integration": "jest tests/integration",
    "test:components": "jest tests/components",
    "test:performance": "jest tests/performance",
    "test:e2e": "jest tests/e2e",
    "test:all": "./run-tests.sh",
    "test:coverage": "jest --coverage",
    "test:coverage:ci": "CI=true jest --coverage --ci --runTestsByPath tests/github-api.test.ts tests/sync.test.ts tests/settings.test.ts tests/path-conversion.test.ts",
    "coverage:report": "jest --coverage && ./generate-coverage.sh",
    "coverage:badge": "npx make-coverage-badge --output-path ./coverage/badge.svg",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "semantic-release": "semantic-release",
    "bundlewatch": "bundlewatch",
    "prepare": "husky install",
    "precommit": "lint-staged"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ErnestoCobos/obsidian-wiki-sync.git"
  },
  "homepage": "https://github.com/ErnestoCobos/obsidian-wiki-sync",
  "bugs": {
    "url": "https://github.com/ErnestoCobos/obsidian-wiki-sync/issues"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "github",
    "wiki",
    "sync"
  ],
  "author": "Ernesto Cobos",
  "license": "MIT",
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^29.5.10",
    "@types/node": "^16.11.6",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "bundlewatch": "^0.3.3",
    "builtin-modules": "3.3.0",
    "esbuild": "0.17.3",
    "eslint": "^8.47.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jest": "^27.6.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^14.0.1",
    "make-coverage-badge": "^1.2.0",
    "obsidian": "latest",
    "prettier": "^3.0.3",
    "semantic-release": "^22.0.8",
    "ts-jest": "^29.1.1",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.0"
  }
}
